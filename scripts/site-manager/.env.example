# ═══════════════════════════════════════════════════════
# מנהל האתר — Mango Realty Site Manager
# Copy this file to .env and fill in your credentials
# ═══════════════════════════════════════════════════════

# ── Folder to watch ────────────────────────────────────
# Full path to the folder containing property subfolders
# Example: C:\Users\YourName\Desktop\נכסים חדשים
WATCH_FOLDER=

# ── Anthropic (Claude) ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Twilio WhatsApp ────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
# Your Twilio WhatsApp sandbox/business number (with whatsapp: prefix)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Admin phone to receive approval requests (with whatsapp: prefix)
ADMIN_WHATSAPP=whatsapp:+972...

# ── Supabase ───────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
# Use the service_role key (bypasses RLS — keep secret!)
SUPABASE_SERVICE_KEY=eyJ...

# ── Optional ───────────────────────────────────────────
# Public base URL for property links in notifications
SITE_URL=https://mango-realty.com
